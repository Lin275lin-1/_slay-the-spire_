[ext_resource type="Script" uid="uid://cff53ccvxdc3t" path="res://scripts/costum_resources/incident_data.gd" id="1_c48bn"]

[resource]
script = ExtResource("1_c48bn")
backgroundPath = "res://images/events/aroma_of_chaos.png"
incidentName = "aroma_of_chaos"
stage = 1
eventTitile = "混沌芳香"
eventDescription = "费力地穿过一片厚密的灌木丛并来到空地后，
一种莫名的怀旧感突然向你袭来。
那是花朵的芬芳、腐烂的恶臭以及某种无法言说的气息的混合体。
每前进一步，这股气味都变得愈发浓烈。
与此同时，你感受到周围的世界正开始扭曲，旋转。
一股变幻莫测的混沌[/rainbow]将你淹没，你开始慢慢地丧失了对自我的感知。"
option1Description = "放任自流
附魔你牌组中的一张牌"
option2Description = "维持理智
升级你拍照中的一张牌"
press_op1_title = Array[String](["放任自流"])
press_op1_description = Array[String](["你选择了屈服，任由你的思绪渐行渐远…
你看见了自己正与朋友们谈笑风生，作为团队的一员并肩作战，
与强敌生死对决。这是梦境？还是现实？又或是两者皆有？
无数双眼睛正注视着你和你的梦。它们…是谁…？
不知过了多久，你悠悠转醒。
香气转淡，随着你的意识重归清明，其影响也渐渐消散。
当神志彻底稳定时，你感觉头脑从未有如此清醒过。
那些眼睛…究竟是什么？"])
press_op1_op1description = Array[String](["继续。"])
press_op1_op2description = Array[String](["继续。"])
press_op2_title = Array[String](["维持理智"])
press_op2_description = Array[String](["你抵制住了屈服的诱惑，攀上了一棵树的树梢。
尽管香气无法触及此处，但其残留的影响仍如利爪般撕扯着你的心智。
维持理智并非易事；你将思绪紧紧维系在你的信条之上。"])
press_op2_op1description = Array[String](["继续。"])
press_op2_op2description = Array[String](["继续。"])
metadata/_custom_type_script = "uid://cff53ccvxdc3t"
